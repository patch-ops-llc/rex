{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@rex/shared": ["packages/shared/src"],
      "@rex/orchestrator": ["packages/orchestrator/src"],
      "@rex/enablement": ["packages/enablement/src"],
      "@rex/hubspot-engine": ["packages/hubspot-engine/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
