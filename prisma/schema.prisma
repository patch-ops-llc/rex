generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// CORE ENGAGEMENT MODEL
// ============================================================

model Engagement {
  id              String           @id @default(cuid())
  name            String
  clientName      String
  industry        String?
  hubspotTier     String?
  hubspotPortalId String?
  hubspotPortal   HubSpotPortal?   @relation(fields: [hubspotPortalId], references: [id], onDelete: SetNull)
  status          EngagementStatus @default(CREATED)
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  discoveryCalls     DiscoveryCall[]
  buildPlan          BuildPlan?
  implementations    Implementation[]
  qaItems            QAItem[]
  enablementSessions EnablementSession[]
  walkthroughs       Walkthrough[]
  conversations      ClientConversation[]
  workRequests       WorkRequest[]
  slackMapping       ClientSlackMapping?
  emailMapping       ClientEmailMapping?
  sow                SOW?
  scopeAlerts        ScopeAlert[]
  phases             ProjectPhase[]
  tasks              ProjectTask[]
  requirementItems   RequirementItem[]
  uatItems           UATItem[]
  deliveryLog        DeliveryLogEntry[]
  scopeDocuments     ScopeDocument[]
}

enum EngagementStatus {
  CREATED
  SCHEDULED
  DISCOVERY
  PLAN_GENERATION
  PLAN_REVIEW
  IMPLEMENTING
  QA
  ENABLEMENT
  ACTIVE_SUPPORT
  COMPLETE
}

// ============================================================
// DISCOVERY
// ============================================================

model DiscoveryCall {
  id             String     @id @default(cuid())
  engagementId   String
  engagement     Engagement @relation(fields: [engagementId], references: [id])
  meetingUrl     String?
  recallBotId    String?
  sessionId      String?    @unique
  platform       String?
  title          String?
  status         CallStatus @default(SCHEDULED)
  autonomyLevel  Int        @default(1)
  rawTranscript  Json?
  structuredData Json?
  decisionTree   Json?
  summary        String?
  speakerProfiles Json?
  duration       Int?
  startedAt      DateTime?
  endedAt        DateTime?
  lastProcessedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  segments       TranscriptSegment[]
  insights       CallInsight[]
}

// ============================================================
// REAL-TIME TRANSCRIPT SEGMENTS
// ============================================================

model TranscriptSegment {
  id              String        @id @default(cuid())
  discoveryCallId String
  discoveryCall   DiscoveryCall @relation(fields: [discoveryCallId], references: [id], onDelete: Cascade)
  speaker         String
  text            String
  startTime       Float
  endTime         Float
  confidence      Float?
  isFinal         Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([discoveryCallId, startTime])
}

// ============================================================
// AI-EXTRACTED CALL INSIGHTS
// ============================================================

model CallInsight {
  id              String        @id @default(cuid())
  discoveryCallId String
  discoveryCall   DiscoveryCall @relation(fields: [discoveryCallId], references: [id], onDelete: Cascade)
  type            InsightType
  content         String
  speaker         String?
  timestamp       Float?
  confidence      Float?
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@index([discoveryCallId, type])
}

enum InsightType {
  REQUIREMENT
  ACTION_ITEM
  DECISION
  SCOPE_CONCERN
  SYSTEM_MENTION
  TIMELINE
  OPEN_QUESTION
  STAKEHOLDER_NOTE
}

enum CallStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ============================================================
// BUILD PLANNING & IMPLEMENTATION
// ============================================================

model BuildPlan {
  id           String     @id @default(cuid())
  engagementId String     @unique
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  version      Int        @default(1)
  status       PlanStatus @default(DRAFT)
  planData     Json
  humanEdits   Json?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum PlanStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTING
  COMPLETED
}

model Implementation {
  id              String     @id @default(cuid())
  engagementId    String
  engagement      Engagement @relation(fields: [engagementId], references: [id])
  stepType        String
  stepName        String
  stepOrder       Int
  config          Json
  status          StepStatus @default(PENDING)
  hubspotResponse Json?
  rollbackData    Json?
  errorMessage    String?
  executedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  ROLLED_BACK
  NEEDS_REVIEW
}

// ============================================================
// QA & ENABLEMENT
// ============================================================

model QAItem {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  category     String
  description  String
  status       QAStatus   @default(PENDING)
  assignedTo   String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum QAStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}

model EnablementSession {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  type         String
  status       String     @default("DRAFT")
  content      Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ============================================================
// WALKTHROUGHS — Interactive Enablement Guides
// ============================================================

model Walkthrough {
  id             String            @id @default(cuid())
  engagementId   String
  engagement     Engagement        @relation(fields: [engagementId], references: [id])
  title          String
  description    String?
  status         WalkthroughStatus @default(GENERATING)
  shareToken     String            @unique @default(cuid())
  steps          WalkthroughStep[]
  generatedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([engagementId])
}

model WalkthroughStep {
  id              String      @id @default(cuid())
  walkthroughId   String
  walkthrough     Walkthrough @relation(fields: [walkthroughId], references: [id], onDelete: Cascade)
  stepOrder       Int
  category        String
  title           String
  narration       String
  context         String?
  screenshotUrl   String?
  annotations     Json?
  linkedStepId    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([walkthroughId, stepOrder])
}

enum WalkthroughStatus {
  GENERATING
  CAPTURING
  NARRATING
  READY
  FAILED
}

// ============================================================
// CLIENT AGENT (Ongoing Support)
// ============================================================

model ClientSlackMapping {
  id             String     @id @default(cuid())
  slackTeamId    String     @unique
  slackChannelId String?
  engagementId   String     @unique
  engagement     Engagement @relation(fields: [engagementId], references: [id])
  botToken       String
  createdAt      DateTime   @default(now())
}

model ClientEmailMapping {
  id               String     @id @default(cuid())
  emailDomain      String
  engagementId     String     @unique
  engagement       Engagement @relation(fields: [engagementId], references: [id])
  authorizedEmails String[]
  createdAt        DateTime   @default(now())
}

model ClientConversation {
  id              String     @id @default(cuid())
  engagementId    String
  engagement      Engagement @relation(fields: [engagementId], references: [id])
  platform        String
  userId          String
  userMessage     String
  agentResponse   String
  intent          String
  actionTaken     String?
  executionPlanId String?
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime   @default(now())
}

model WorkRequest {
  id              String            @id @default(cuid())
  engagementId    String
  engagement      Engagement        @relation(fields: [engagementId], references: [id])
  requestedBy     String
  requestText     String
  executionPlan   Json
  riskAssessment  Json
  status          WorkRequestStatus @default(PENDING_APPROVAL)
  approvedBy      String?
  approvedAt      DateTime?
  deniedReason    String?
  executionLog    Json?
  verificationLog Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum WorkRequestStatus {
  PENDING_APPROVAL
  APPROVED
  DENIED
  EXECUTING
  VERIFYING
  COMPLETED
  FAILED
}

// ============================================================
// INTERNAL CHAT SESSIONS (Rex UI)
// ============================================================

model ChatSession {
  id        String        @id @default(cuid())
  title     String?
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String
  content      String
  toolActivity Json?
  createdAt    DateTime    @default(now())
}

// ============================================================
// TRAINING CORPUS
// ============================================================

model CorpusEntry {
  id         String   @id @default(cuid())
  name       String
  transcript Json
  annotations Json?
  tags       String[]
  industry   String?
  complexity String?
  outcome    String?
  category   String?
  source     String?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================
// SLACK WORKSPACE CONNECTIONS (OAuth multi-workspace)
// ============================================================

model SlackWorkspace {
  id          String   @id @default(cuid())
  teamId      String   @unique
  teamName    String
  accessToken String
  botUserId   String?
  scope       String?
  installedBy String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// HUBSPOT PORTAL CONNECTIONS
// ============================================================

model HubSpotPortal {
  id             String       @id @default(cuid())
  name           String
  portalId       String       @unique
  accessToken    String
  isActive       Boolean      @default(true)
  lastVerifiedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  engagements    Engagement[]
}

// ============================================================
// PROJECT PIPELINE — PHASE & TASK TRACKING
// ============================================================

model ProjectPhase {
  id             String       @id @default(cuid())
  engagementId   String
  engagement     Engagement   @relation(fields: [engagementId], references: [id])
  phaseType      PhaseType
  status         PhaseStatus  @default(NOT_STARTED)
  displayOrder   Int
  startedAt      DateTime?
  completedAt    DateTime?
  blockedReason  String?
  outputSummary  Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tasks          ProjectTask[] @relation("PhaseTasks")

  @@unique([engagementId, phaseType])
}

enum PhaseType {
  SOW_SETUP
  DISCOVERY_PREP
  DISCOVERY
  REQUIREMENTS
  BUILD_PLANNING
  BUILD_APPROVAL
  IMPLEMENTATION
  HUMAN_CLEANUP
  UAT
  CLOSEOUT
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_ON_CLIENT
  WAITING_ON_APPROVAL
  BLOCKED
  COMPLETED
  SKIPPED
}

model ProjectTask {
  id             String       @id @default(cuid())
  engagementId   String
  engagement     Engagement   @relation(fields: [engagementId], references: [id])
  phaseId        String?
  phase          ProjectPhase? @relation("PhaseTasks", fields: [phaseId], references: [id])
  phaseType      PhaseType
  title          String
  description    String?
  status         TaskStatus   @default(PENDING)
  taskType       TaskType     @default(AUTO)
  assignedTo     String?
  sourceId       String?
  sourceType     String?
  outputData     Json?
  errorMessage   String?
  displayOrder   Int          @default(0)
  dueAt          DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  WAITING_ON_CLIENT
  WAITING_ON_APPROVAL
  COMPLETED
  FAILED
  SKIPPED
}

enum TaskType {
  AUTO
  HUMAN
  CLIENT_ACTION
  APPROVAL
  REVIEW
}

// ============================================================
// ASYNC REQUIREMENTS GATHERING (Client Portal)
// ============================================================

model RequirementItem {
  id             String            @id @default(cuid())
  engagementId   String
  engagement     Engagement        @relation(fields: [engagementId], references: [id])
  category       String
  question       String
  context        String?
  answer         String?
  answeredBy     String?
  answeredAt     DateTime?
  status         RequirementStatus @default(PENDING)
  priority       String            @default("MEDIUM")
  sowLineItemId  String?
  displayOrder   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum RequirementStatus {
  PENDING
  ANSWERED
  CLARIFICATION_NEEDED
  CONFIRMED
  NOT_APPLICABLE
}

// ============================================================
// UAT — User Acceptance Testing (Client Portal)
// ============================================================

model UATItem {
  id             String     @id @default(cuid())
  engagementId   String
  engagement     Engagement @relation(fields: [engagementId], references: [id])
  category       String
  title          String
  description    String
  testSteps      String?
  expectedResult String?
  status         UATStatus  @default(NOT_TESTED)
  testedBy       String?
  testedAt       DateTime?
  clientNotes    String?
  linkedStepId   String?
  displayOrder   Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum UATStatus {
  NOT_TESTED
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

// ============================================================
// CUSTOM PROJECTS — GitHub + Railway Pipeline
// ============================================================

model CustomProject {
  id               String              @id @default(cuid())
  name             String
  description      String?
  engagementId     String?
  templateType     String              @default("express-integration")

  // GitHub
  githubRepo       String?             // "org/repo-name"
  githubRepoUrl    String?
  githubBranch     String              @default("main")

  // Railway
  railwayProjectId String?             @unique
  railwayServiceId String?
  railwayUrl       String?

  status           ProjectDeployStatus @default(CREATED)
  envVars          Json?               // non-secret env var config
  scaffoldConfig   Json?               // template params (ports, db, etc.)
  lastDeployedAt   DateTime?
  errorMessage     String?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

enum ProjectDeployStatus {
  CREATED
  REPO_CREATED
  SCAFFOLDED
  RAILWAY_LINKED
  DEPLOYING
  DEPLOYED
  DEPLOY_FAILED
}

// ============================================================
// SCOPE DOCUMENTS — File-based scope ingestion
// ============================================================

model ScopeDocument {
  id             String              @id @default(cuid())
  engagementId   String
  engagement     Engagement          @relation(fields: [engagementId], references: [id])
  fileName       String
  fileType       String
  fileSizeBytes  Int?
  slackFileId    String?             @unique
  slackChannelId String?
  slackUserId    String?
  rawText        String?
  parsedData     Json?
  status         ScopeDocumentStatus @default(UPLOADED)
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([engagementId])
}

enum ScopeDocumentStatus {
  UPLOADED
  PARSING
  PARSED
  PROCESSING
  PROCESSED
  FAILED
}

// ============================================================
// DELIVERY LOG — PM Audit Trail
// ============================================================

model DeliveryLogEntry {
  id             String     @id @default(cuid())
  engagementId   String
  engagement     Engagement @relation(fields: [engagementId], references: [id])
  action         String
  phaseType      PhaseType?
  actor          String
  description    String
  metadata       Json?
  createdAt      DateTime   @default(now())
}

// ============================================================
// SOW & SCOPE TRACKING
// ============================================================

model SOW {
  id             String      @id @default(cuid())
  engagementId   String      @unique
  engagement     Engagement  @relation(fields: [engagementId], references: [id])
  title          String
  version        Int         @default(1)
  status         SOWStatus   @default(DRAFT)
  totalBudget    Float?
  totalHours     Float?
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  lineItems      SOWLineItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum SOWStatus {
  DRAFT
  ACTIVE
  AMENDED
  COMPLETE
  CANCELLED
}

model SOWLineItem {
  id              String   @id @default(cuid())
  sowId           String
  sow             SOW      @relation(fields: [sowId], references: [id], onDelete: Cascade)
  workstream      String
  description     String?
  allocatedHours  Float
  consumedHours   Float    @default(0)
  rateTier        String   @default("TIER_1")
  hourlyRate      Float    @default(100)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ScopeAlert {
  id             String          @id @default(cuid())
  engagementId   String
  engagement     Engagement      @relation(fields: [engagementId], references: [id])
  type           ScopeAlertType
  severity       AlertSeverity   @default(INFO)
  title          String
  description    String
  workstream     String?
  hoursImpact    Float?
  budgetImpact   Float?
  sourceId       String?
  sourceType     String?
  status         AlertStatus     @default(OPEN)
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum ScopeAlertType {
  SCOPE_CREEP
  OUT_OF_SCOPE
  OVER_BUDGET
  OVER_HOURS
  APPROACHING_LIMIT
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}
