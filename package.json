{
  "name": "rex",
  "private": true,
  "scripts": {
    "build": "prisma generate && turbo run build --filter=@rex/web && cp -r apps/web/.next/static apps/web/.next/standalone/apps/web/.next/static",
    "start": "node apps/web/.next/standalone/apps/web/server.js",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "mammoth": "^1.12.0",
    "prisma": "^6",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "^6"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
